# VPS Guardian - Configuração de Exemplo
# Copie para /opt/vps-guardian/guardian/config.yaml e ajuste conforme necessário

detection:
  # Termos suspeitos para detecção de mineradores
  # IMPORTANTE: NÃO adicione nomes de processos do kernel (kworker, ksoftirqd, etc.)
  # Apenas adicione nomes de MALWARE conhecidos
  suspicious_terms:
    # Mineradores conhecidos
    - xmrig
    - xmr-stak
    - monero
    - cpuminer
    - ethminer
    - cryptonight
    - ccminer
    - cgminer
    - bfgminer
    - minerd
    # Pools de mineração
    - stratum
    - pool.minexmr
    - supportxmr
    - nanopool
    - f2pool
    - hashvault
    - nicehash
    - minergate
    # Malware específico (nomes que imitam processos do kernel)
    - kworkerds
    - kdevtmpfsi
    - kinsing
    - perfctl
    - perfcc

  # Intervalo de varredura em segundos
  scan_interval_seconds: 5

  # Whitelist de processos de build/desenvolvimento
  # Estes processos podem executar de /tmp durante compilação sem serem bloqueados
  # O Guardian já tem uma lista interna (maturin, cargo, rustc, pip, npm, etc.)
  # Adicione outros se necessário:
  build_whitelist: []
  # Exemplo:
  # build_whitelist:
  #   - custom-compiler
  #   - my-build-tool

# Monitoramento de Recursos
# Premissa: Nenhum processo legítimo consome >75% por mais de 10 minutos
resources:
  # Threshold de CPU (porcentagem)
  cpu_threshold_percent: 75

  # Threshold de memória (porcentagem)
  memory_threshold_percent: 75

  # Notificar após N minutos de uso alto
  notify_after_minutes: 10

  # Matar processo após N minutos de uso alto
  kill_after_minutes: 20

  # Limite da VPS antes de bloqueio por abuso (referência)
  vps_abuse_limit_minutes: 90

  # Whitelist de processos (APENAS essenciais do sistema)
  whitelist:
    - dockerd
    - containerd
    - systemd
    - sshd
    - guardian.py
    - journald
    - networkd
    # Adicione outros processos legítimos se necessário

# Monitoramento de Rede
network:
  # Caminho para lista de mining pools
  mining_pools_list: /opt/vps-guardian/firewall/blocklists/mining-pools.txt

  # Caminho para lista de exit nodes TOR
  tor_nodes_list: /opt/vps-guardian/firewall/blocklists/tor-exit-nodes.txt

  # Portas suspeitas de mining
  suspicious_ports:
    - 3333
    - 8888
    - 14444
    - 5555
    - 7777

# Resposta a Incidentes
response:
  # Diretório para quarentena de binários suspeitos
  quarantine_dir: /var/quarantine

  # Arquivo de log
  log_file: /var/log/guardian.log

  # Notificações Telegram (opcional)
  telegram:
    enabled: false
    webhook_url: "https://api.telegram.org/bot<SEU_TOKEN>/sendMessage"
    chat_id: "<SEU_CHAT_ID>"

# Verificação de Integridade
integrity:
  # Binários críticos para verificação de hash
  critical_binaries:
    - /usr/bin/ps
    - /usr/bin/top
    - /bin/ls
    - /usr/bin/lsof
    - /usr/bin/netstat
    - /usr/bin/ss
    - /usr/sbin/sshd
    - /usr/bin/find
    - /usr/bin/grep

  # Banco de dados de hashes
  hash_db: /var/lib/guardian/hashes.json

# Monitoramento de Filesystem
filesystem:
  # Diretórios para monitorar (executáveis suspeitos)
  watch_dirs:
    - /tmp
    - /dev/shm
    - /var/tmp

  # Arquivos modificados nos últimos N minutos são considerados suspeitos
  max_file_age_minutes: 30
